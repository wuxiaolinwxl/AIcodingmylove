PORT=3000
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=ms_user
DB_PASSWORD=ms_password_123
DB_NAME=memory_space
# Set to "true" only in dev to let TypeORM auto-sync schema. NEVER enable in production.
DB_SYNCHRONIZE=false

# REQUIRED. App refuses to start if missing. Use a long random string (>=32 chars).
JWT_SECRET=change_me_to_a_random_64_char_string_for_production_use_only
JWT_EXPIRES_IN=7d

# Local file storage root for uploaded media (served at /uploads/<key>).
UPLOAD_DIR=/root/AIcoding/uploads

# Web Push (VAPID). Generate with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@memory-space.local

# Comma-separated allowed origins. Applies to both HTTP and WebSocket (/chat).
CORS_ORIGIN=http://localhost:5173
